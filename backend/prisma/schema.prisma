generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"

}

enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  IN_SHOP
  RETIRED
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  OFF_DUTY
  SUSPENDED
}

enum TripStatus {
  DRAFT
  DISPATCHED
  COMPLETED
  CANCELLED
}

model Vehicle {
  id                String        @id @default(cuid())
  status            VehicleStatus @default(AVAILABLE)
  maxLoadCapacityKg Int
  odometerKm        Int?

  trips           Trip[]
  maintenanceLogs MaintenanceLog[]
  fuelLogs        FuelLog[]
  expenses        Expense[]
}

model Driver {
  id                String       @id @default(cuid())
  status            DriverStatus @default(AVAILABLE)
  licenseExpiryDate DateTime

  trips Trip[]
}

enum MaintenanceStatus {
  ACTIVE
  CLOSED
}

model MaintenanceLog {
  id                String            @id @default(cuid())
  vehicleId         String
  type              String
  description       String?
  cost              Decimal
  status            MaintenanceStatus @default(ACTIVE)
  scheduledDate     DateTime
  closedDate        DateTime?
  odometerAtService Int
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
}

model FuelLog {
  id        String   @id @default(cuid())
  vehicleId String
  tripId    String?
  liters    Float
  cost      Float
  date      DateTime
  createdAt DateTime @default(now())

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
  trip    Trip?   @relation(fields: [tripId], references: [id])
}

model Expense {
  id        String   @id @default(cuid())
  vehicleId String?
  tripId    String?
  category  String
  amount    Float
  date      DateTime
  notes     String?
  createdAt DateTime @default(now())

  vehicle Vehicle? @relation(fields: [vehicleId], references: [id])
  trip    Trip?    @relation(fields: [tripId], references: [id])
}

model Trip {
  id                 String     @id @default(cuid())
  status             TripStatus @default(DRAFT)
  cargoWeightKg      Int
  vehicleId          String
  driverId           String
  dispatchedAt       DateTime?
  actualDistanceKm   Int?
  fuelConsumedLiters Float?
  completedAt        DateTime?

  vehicle  Vehicle   @relation(fields: [vehicleId], references: [id])
  driver   Driver    @relation(fields: [driverId], references: [id])
  fuelLogs FuelLog[]
  expenses Expense[]
}
